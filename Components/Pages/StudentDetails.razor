@page "/students/details/{Id:int}"
@rendermode InteractiveServer
@using BlazorAcademyTop.Models
@using BlazorAcademyTop.Data
@using Microsoft.EntityFrameworkCore
@inject AcademyContext Context
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Профиль студента</h3>
            <button class="btn btn-light btn-sm" @onclick="GoBack">Назад к списку</button>
        </div>
        <div class="card-body">
            @if (student == null)
            {
                <div class="text-center"><div class="spinner-border"></div><p>Загрузка...</p></div>
            }
            else
            {
                <div class="row">
                    <div class="col-md-4 text-center border-end">
                        @if (student.Photo != null && student.Photo.Length > 0)
                        {
                            <img src="data:image/jpeg;base64,@Convert.ToBase64String(student.Photo)" class="img-fluid rounded shadow-sm" style="max-height: 300px;" />
                        }
                        else
                        {
                            <div class="bg-light border rounded d-flex align-items-center justify-content-center" style="height: 300px;">
                                <span class="text-muted">Нет фото</span>
                            </div>
                        }
                    </div>
                    <div class="col-md-8 ps-4">
                        <h2 class="text-primary">@student.LastName @student.FirstName @student.MiddleName</h2>
                        <hr />
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">Группа:</div>
                            <div class="col-sm-8">@(student.Group?.GroupName ?? "Не назначена")</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">Дата рождения:</div>
                            <div class="col-sm-8">@student.BirthDate.ToShortDateString() (@student.AgeString)</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">Email:</div>
                            <div class="col-sm-8">@student.Email</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-4 fw-bold">Телефон:</div>
                            <div class="col-sm-8">@student.Phone</div>
                        </div>
                        <div class="mt-4">
                            <a href="/students/edit/@student.StudId" class="btn btn-warning">Редактировать</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private Student? student;

    protected override async Task OnInitializedAsync()
    {
        student = await Context.Students.Include(s => s.Group).FirstOrDefaultAsync(s => s.StudId == Id);
    }
    private void GoBack() => Navigation.NavigateTo("/students");
}