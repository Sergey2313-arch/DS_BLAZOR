@page "/students"
@rendermode InteractiveServer
@using BlazorAcademyTop.Models
@using BlazorAcademyTop.Data
@using Microsoft.EntityFrameworkCore
@inject AcademyContext Context

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Студенты</h3>
    <a href="/students/edit" class="btn btn-success">Добавить студента</a>
</div>

<div class="mb-3">
    <select class="form-select w-25" @onchange="OnGroupChanged">
        <option value="">-- Все группы --</option>
        @if (groups != null)
        {
            @foreach (var g in groups)
            {
                <option value="@g.GroupId">@g.GroupName</option>
            }
        }
    </select>
</div>

<table class="table table-bordered table-hover shadow-sm">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>ФИО</th>
            <th>Возраст</th>
            <th>Группа</th>
            <th class="text-center">Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (students != null)
        {
            @foreach (var s in students)
            {
                <tr>
                    <td>@s.StudId</td>
                    <td>@s.LastName @s.FirstName @s.MiddleName</td>
                    <td>@s.AgeString</td>
                    <td>@(s.Group?.GroupName ?? "—")</td>
                    <td class="text-center">
                        <a href="/students/details/@s.StudId" class="btn btn-sm btn-info text-white">👁️</a>
                        <a href="/students/edit/@s.StudId" class="btn btn-sm btn-warning">✏️</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="d-flex justify-content-between mt-3">
    <button class="btn btn-primary" @onclick="PrevPage" disabled="@(currentPage == 1)">Назад</button>
    <span class="fw-bold">Страница @currentPage из @totalPages</span>
    <button class="btn btn-primary" @onclick="NextPage" disabled="@(currentPage >= totalPages)">Вперед</button>
</div>

@code {
    private List<Student>? students;
    private List<Group>? groups;
    private int? selectedGroupId;
    private int currentPage = 1;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        groups = await Context.Groups.ToListAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        var query = Context.Students.Include(s => s.Group).AsQueryable();
        if (selectedGroupId.HasValue) query = query.Where(s => s.GroupId == selectedGroupId.Value);

        var count = await query.CountAsync();
        totalPages = (int)Math.Ceiling(count / 10.0);
        if (totalPages <= 0) totalPages = 1;

        students = await query.OrderBy(s => s.StudId).Skip((currentPage - 1) * 10).Take(10).ToListAsync();
        StateHasChanged();
    }

    private async Task OnGroupChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id)) selectedGroupId = id;
        else selectedGroupId = null;
        currentPage = 1;
        await LoadData();
    }

    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadData(); } }
    private async Task NextPage() { if (currentPage < totalPages) { currentPage++; await LoadData(); } }
}