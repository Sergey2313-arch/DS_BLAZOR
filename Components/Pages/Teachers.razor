@page "/teachers"
@rendermode InteractiveServer
@using BlazorAcademyTop.Models
@using BlazorAcademyTop.Data
@using Microsoft.EntityFrameworkCore
@inject AcademyContext Context

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Преподаватели</h3>
    <a href="/teachers/edit" class="btn btn-success">Добавить преподавателя</a>
</div>

<table class="table table-bordered table-hover shadow-sm">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>ФИО</th>
            <th>Возраст</th>
            <th class="text-center">Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (teachers != null)
        {
            @foreach (var t in teachers)
            {
                <tr>
                    <td>@t.TeacherId</td>
                    <td>@t.FullName</td>
                    <td>@t.AgeString</td>
                    <td class="text-center">
                        <a href="/teachers/details/@t.TeacherId" class="btn btn-sm btn-info text-white">👁️ Карточка</a>
                        <a href="/teachers/edit/@t.TeacherId" class="btn btn-sm btn-warning">✏️</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="d-flex justify-content-between mt-3">
    <button class="btn btn-primary" @onclick="PrevPage" disabled="@(currentPage == 1)">Назад</button>
    <span>Страница @currentPage из @totalPages</span>
    <button class="btn btn-primary" @onclick="NextPage" disabled="@(currentPage >= totalPages)">Вперед</button>
</div>

@code {
    private List<Teacher>? teachers;
    private int currentPage = 1;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var query = Context.Teachers.AsQueryable();
        var count = await query.CountAsync();
        totalPages = (int)Math.Ceiling(count / 10.0);
        if (totalPages <= 0) totalPages = 1;

        teachers = await query.OrderBy(t => t.TeacherId).Skip((currentPage - 1) * 10).Take(10).ToListAsync();
        StateHasChanged();
    }

    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadData(); } }
    private async Task NextPage() { if (currentPage < totalPages) { currentPage++; await LoadData(); } }
}