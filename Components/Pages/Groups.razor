@page "/groups"
@rendermode InteractiveServer
@using BlazorAcademyTop.Models
@using BlazorAcademyTop.Data
@using Microsoft.EntityFrameworkCore
@inject AcademyContext Context

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Группы</h3>
    <a href="/groups/edit" class="btn btn-success">Добавить группу</a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Название группы</th>
            <th>Направление</th>
            <th class="text-center">Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (groups != null)
        {
            @foreach (var g in groups)
            {
                <tr>
                    <td>@g.GroupId</td>
                    <td>@g.GroupName</td>
                    <td>@(g.Direction?.DirectionName ?? "—")</td>
                    <td class="text-center">
                        <a href="/groups/edit/@g.GroupId" class="btn btn-sm btn-warning">✏️ Редактировать</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="d-flex justify-content-between mt-3">
    <button class="btn btn-primary" @onclick="PrevPage" disabled="@(currentPage == 1)">Назад</button>
    <span>Страница @currentPage из @totalPages</span>
    <button class="btn btn-primary" @onclick="NextPage" disabled="@(currentPage >= totalPages)">Вперед</button>
</div>

@code {
    private List<Group>? groups;
    private int currentPage = 1;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var query = Context.Groups.Include(g => g.Direction).AsQueryable();
        var count = await query.CountAsync();
        totalPages = (int)Math.Ceiling(count / 10.0);
        if (totalPages <= 0) totalPages = 1;

        groups = await query.OrderBy(g => g.GroupId).Skip((currentPage - 1) * 10).Take(10).ToListAsync();
        StateHasChanged();
    }

    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadData(); } }
    private async Task NextPage() { if (currentPage < totalPages) { currentPage++; await LoadData(); } }
}