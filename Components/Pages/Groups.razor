@page "/groups"
@rendermode InteractiveServer
@using BlazorAcademyTop.Data
@using BlazorAcademyTop.Models
@using Microsoft.EntityFrameworkCore
@inject AcademyContext Db

<h1>Groups</h1>

<div id="editForm" class="card p-3 mb-3">
    <h4>@(editGroup.GroupId == 0 ? "Добавить группу" : "Изменить группу")</h4>

    <div class="row g-2">
        <div class="col-md-4">
            <label class="form-label">Название группы</label>
            <input class="form-control" @bind="editGroup.GroupName" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Направление обучения</label>
            <select class="form-select" @bind="editGroup.DirectionId">
                <option value="">-- выберите направление --</option>
                @foreach (var d in directions)
                {
                    <option value="@d.DirectionId">@d.DirectionName</option>
                }
            </select>
        </div>
    </div>

    <div class="mt-3">
        <label class="form-label d-block">Учебные дни</label>

        <label class="me-3"><input type="checkbox" @bind="editGroup.Monday" /> Пн.</label>
        <label class="me-3"><input type="checkbox" @bind="editGroup.Tuesday" /> Вт.</label>
        <label class="me-3"><input type="checkbox" @bind="editGroup.Wednesday" /> Ср.</label>
        <label class="me-3"><input type="checkbox" @bind="editGroup.Thursday" /> Чт.</label>
        <label class="me-3"><input type="checkbox" @bind="editGroup.Friday" /> Пт.</label>
        <label class="me-3"><input type="checkbox" @bind="editGroup.Saturday" /> Сб.</label>
        <label class="me-3"><input type="checkbox" @bind="editGroup.Sunday" /> Вс.</label>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary me-2" @onclick="SaveGroup">Сохранить</button>
        <button class="btn btn-secondary" @onclick="CancelEdit">Очистить</button>
    </div>
</div>

<div class="card p-3 mb-3">
    <label class="form-label">Фильтр по направлению</label>
    <select class="form-select" @bind="selectedDirectionId" @bind:after="LoadGroups">
        <option value="">Все направления</option>
        @foreach (var d in directions)
        {
            <option value="@d.DirectionId">@d.DirectionName</option>
        }
    </select>
</div>

@if (items == null)
{
    <p>Загрузка...</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Группа</th>
                <th>Направление</th>
                <th>Учебные дни</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var g in items)
            {
                <tr>
                    <td>@g.GroupId</td>
                    <td>@g.GroupName</td>
                    <td>@g.Direction?.DirectionName</td>
                    <td>@GetStudyDays(g)</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => StartEdit(g)">
                            Изменить
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Group>? items;
    private List<Direction> directions = new();
    private byte? selectedDirectionId;
    private Group editGroup = new();

    protected override async Task OnInitializedAsync()
    {
        directions = await Db.Directions
            .AsNoTracking()
            .OrderBy(d => d.DirectionName)
            .ToListAsync();

        await LoadGroups();
    }

    private async Task LoadGroups()
    {
        var query = Db.Groups
            .Include(g => g.Direction)
            .AsNoTracking()
            .AsQueryable();

        if (selectedDirectionId.HasValue)
        {
            query = query.Where(g => g.DirectionId == selectedDirectionId.Value);
        }

        items = await query.OrderBy(g => g.GroupName).ToListAsync();
    }

    private void StartEdit(Group group)
    {
        editGroup = new Group
        {
            GroupId = group.GroupId,
            GroupName = group.GroupName,
            DirectionId = group.DirectionId,
            Monday = group.Monday,
            Tuesday = group.Tuesday,
            Wednesday = group.Wednesday,
            Thursday = group.Thursday,
            Friday = group.Friday,
            Saturday = group.Saturday,
            Sunday = group.Sunday
        };
    }

    private void CancelEdit()
    {
        editGroup = new Group();
    }

    private async Task SaveGroup()
    {
        if (string.IsNullOrWhiteSpace(editGroup.GroupName))
            return;

        if (editGroup.GroupId == 0)
        {
            editGroup.GroupId = (await Db.Groups.MaxAsync(g => (int?)g.GroupId) ?? 0) + 1;
            Db.Groups.Add(editGroup);
        }
        else
        {
            Db.Groups.Update(editGroup);
        }

        await Db.SaveChangesAsync();

        editGroup = new Group();
        await LoadGroups();
    }

    private string GetStudyDays(Group g)
    {
        var days = new List<string>();

        if (g.Monday) days.Add("Пн");
        if (g.Tuesday) days.Add("Вт");
        if (g.Wednesday) days.Add("Ср");
        if (g.Thursday) days.Add("Чт");
        if (g.Friday) days.Add("Пт");
        if (g.Saturday) days.Add("Сб");
        if (g.Sunday) days.Add("Вс");

        return days.Count == 0 ? "Не выбрано" : string.Join(", ", days);
    }
}