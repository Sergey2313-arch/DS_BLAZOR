@page "/disciplines"
@rendermode InteractiveServer
@using BlazorAcademyTop.Models
@using BlazorAcademyTop.Data
@using Microsoft.EntityFrameworkCore

@inject AcademyContext Context

<h3>Дисциплины</h3>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Название предмета</th>
        </tr>
    </thead>
    <tbody>
        @if (disciplines != null)
        {
            @foreach (var d in disciplines)
            {
                <tr>
                    <td>@d.DisciplineId</td>
                    <td>@d.DisciplineName</td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="d-flex justify-content-between mt-3">
    <button class="btn btn-primary" @onclick="PrevPage" disabled="@(currentPage == 1)">Назад</button>
    <span>Страница @currentPage из @totalPages</span>
    <button class="btn btn-primary" @onclick="NextPage" disabled="@(currentPage >= totalPages)">Вперед</button>
</div>

@code {
    private List<Discipline>? disciplines;
    private int currentPage = 1;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var query = Context.Disciplines.AsQueryable();
        totalPages = (int)Math.Ceiling(await query.CountAsync() / 10.0);
        if (totalPages <= 0) totalPages = 1;
        disciplines = await query.Skip((currentPage - 1) * 10).Take(10).ToListAsync();
        StateHasChanged();
    }

    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadData(); } }
    private async Task NextPage() { if (currentPage < totalPages) { currentPage++; await LoadData(); } }
}